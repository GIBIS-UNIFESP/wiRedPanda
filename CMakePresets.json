{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "build"
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with full debugging information",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "description": "Release build with debug information (used for deployment)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage",
            "description": "Debug build with code coverage instrumentation",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_COVERAGE": "ON",
                "ENABLE_UNITY": "OFF",
                "ENABLE_PCH": "OFF"
            }
        },
        {
            "name": "asan",
            "displayName": "Address Sanitizer",
            "description": "Debug build with Address Sanitizer for memory error detection",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_ADDRESS_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "tsan",
            "displayName": "Thread Sanitizer",
            "description": "Debug build with Thread Sanitizer for race condition detection",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_THREAD_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "msan",
            "displayName": "Memory Sanitizer (Clang)",
            "description": "Debug build with Memory Sanitizer for uninitialized memory detection (Clang only)",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_MEMORY_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UB Sanitizer",
            "description": "Debug build with Undefined Behavior Sanitizer",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_UB_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "macos-universal",
            "displayName": "macOS Universal",
            "description": "Release build for macOS with universal binaries (x86_64 + arm64)",
            "inherits": "release",
            "cacheVariables": {
                "CMAKE_OSX_ARCHITECTURES": "x86_64;arm64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Sentry with Crashpad",
            "description": "RelWithDebInfo build with Sentry crashpad backend",
            "inherits": "relwithdebinfo",
            "cacheVariables": {
                "SENTRY_BACKEND": "crashpad"
            }
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Sentry with Breakpad",
            "description": "RelWithDebInfo build with Sentry breakpad backend for macOS",
            "inherits": "relwithdebinfo",
            "cacheVariables": {
                "SENTRY_BACKEND": "breakpad",
                "CMAKE_OSX_ARCHITECTURES": "x86_64;arm64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "kde",
            "displayName": "KDE Frameworks",
            "description": "Debug build with KDE Frameworks integration enabled (uses system Qt)",
            "inherits": "debug",
            "binaryDir": "build-kde",
            "cacheVariables": {
                "USE_KDE_FRAMEWORKS": "ON",
                "CMAKE_BUILD_RPATH": "/usr/lib/x86_64-linux-gnu",
                "Qt6_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6"},
                "Qt6Core_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Core"},
                "Qt6Gui_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Gui"},
                "Qt6Network_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Network"},
                "Qt6PrintSupport_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6PrintSupport"},
                "Qt6Multimedia_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Multimedia"},
                "Qt6Widgets_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Widgets"},
                "Qt6Svg_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Svg"},
                "Qt6Test_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6Test"},
                "Qt6LinguistTools_DIR": {"type": "PATH", "value": "/usr/lib/x86_64-linux-gnu/cmake/Qt6LinguistTools"}
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release"
        },
        {
            "name": "relwithdebinfo",
            "displayName": "Build RelWithDebInfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "coverage",
            "displayName": "Build Coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "asan",
            "displayName": "Build with AddressSanitizer",
            "configurePreset": "asan"
        },
        {
            "name": "tsan",
            "displayName": "Build with ThreadSanitizer",
            "configurePreset": "tsan"
        },
        {
            "name": "msan",
            "displayName": "Build with MemorySanitizer",
            "configurePreset": "msan"
        },
        {
            "name": "ubsan",
            "displayName": "Build with UBSanitizer",
            "configurePreset": "ubsan"
        },
        {
            "name": "macos-universal",
            "displayName": "Build macOS Universal",
            "configurePreset": "macos-universal"
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Build with Sentry Crashpad",
            "configurePreset": "sentry-crashpad"
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Build with Sentry Breakpad",
            "configurePreset": "sentry-breakpad"
        },
        {
            "name": "kde",
            "displayName": "Build KDE Frameworks",
            "configurePreset": "kde"
        }
    ],
    "testPresets": [
        {
            "name": "base",
            "hidden": true,
            "execution": {
                "jobs": 8
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "debug",
            "displayName": "Test Debug",
            "configurePreset": "debug",
            "inherits": "base"
        },
        {
            "name": "release",
            "displayName": "Test Release",
            "configurePreset": "release",
            "inherits": "base"
        },
        {
            "name": "relwithdebinfo",
            "displayName": "Test RelWithDebInfo",
            "configurePreset": "relwithdebinfo",
            "inherits": "base"
        },
        {
            "name": "coverage",
            "displayName": "Test Coverage",
            "configurePreset": "coverage",
            "inherits": "base"
        },
        {
            "name": "asan",
            "displayName": "Test with AddressSanitizer",
            "configurePreset": "asan",
            "inherits": "base"
        },
        {
            "name": "tsan",
            "displayName": "Test with ThreadSanitizer",
            "configurePreset": "tsan",
            "inherits": "base"
        },
        {
            "name": "msan",
            "displayName": "Test with MemorySanitizer",
            "configurePreset": "msan",
            "inherits": "base"
        },
        {
            "name": "ubsan",
            "displayName": "Test with UBSanitizer",
            "configurePreset": "ubsan",
            "inherits": "base"
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Test with Sentry Crashpad",
            "configurePreset": "sentry-crashpad",
            "inherits": "base"
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Test with Sentry Breakpad",
            "configurePreset": "sentry-breakpad",
            "inherits": "base"
        },
        {
            "name": "kde",
            "displayName": "Test KDE Frameworks",
            "configurePreset": "kde",
            "inherits": "base"
        }
    ]
}
