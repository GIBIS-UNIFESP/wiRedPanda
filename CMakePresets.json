{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "description": "Ninja is required: multi-config generators (Visual Studio) are not supported",
            "generator": "Ninja",
            "binaryDir": "build/${presetName}"
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with full debugging information",
            "inherits": "base",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Optimized release build",
            "inherits": "base",
            "binaryDir": "build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "relwithdebinfo",
			"hidden": true,
            "displayName": "RelWithDebInfo",
            "description": "Release build with debug information (used for deployment)",
            "inherits": "base",
            "binaryDir": "build-relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage",
            "description": "Debug build with code coverage instrumentation",
            "inherits": "debug",
            "binaryDir": "build-coverage",
            "cacheVariables": {
                "ENABLE_COVERAGE": "ON",
                "ENABLE_UNITY": "OFF",
                "ENABLE_PCH": "OFF"
            }
        },
        {
            "name": "asan",
            "displayName": "Address Sanitizer",
            "description": "Debug build with Address Sanitizer for memory error detection",
            "inherits": "debug",
            "binaryDir": "build-asan",
            "cacheVariables": {
                "ENABLE_ADDRESS_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "tsan",
            "displayName": "Thread Sanitizer",
            "description": "Debug build with Thread Sanitizer for race condition detection",
            "inherits": "debug",
            "binaryDir": "build-tsan",
            "cacheVariables": {
                "ENABLE_THREAD_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "msan",
            "displayName": "Memory Sanitizer (Clang)",
            "description": "Debug build with Memory Sanitizer for uninitialized memory detection (Clang only)",
            "inherits": "debug",
            "binaryDir": "build-msan",
            "cacheVariables": {
                "ENABLE_MEMORY_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UB Sanitizer",
            "description": "Debug build with Undefined Behavior Sanitizer",
            "inherits": "debug",
            "binaryDir": "build-ubsan",
            "cacheVariables": {
                "ENABLE_UB_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "macos-universal",
            "hidden": true,
            "displayName": "macOS Universal",
            "description": "Release build for macOS with universal binaries (x86_64 + arm64)",
            "inherits": "release",
            "binaryDir": "build-macos-universal",
            "cacheVariables": {
                "CMAKE_OSX_ARCHITECTURES": "x86_64;arm64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "fuzzer",
            "displayName": "libFuzzer Harness",
            "description": "Clang-only build with libFuzzer + AddressSanitizer + UBSanitizer for the .panda deserializer harness",
            "inherits": "base",
            "binaryDir": "build-fuzzer",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_FUZZER": "ON",
                "ENABLE_ADDRESS_SANITIZER": "ON",
                "ENABLE_UB_SANITIZER": "ON",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF"
            }
        },
        {
            "name": "fuzzer-coverage",
            "displayName": "Fuzzer corpus coverage analysis",
            "description": "Clang source-based coverage build (no sanitizers). Run coverage-report.sh after building to generate an HTML line-coverage report showing which harness code is never reached.",
            "inherits": "base",
            "binaryDir": "build-fuzzer-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_FUZZER": "ON",
                "ENABLE_ADDRESS_SANITIZER": "OFF",
                "ENABLE_UB_SANITIZER": "OFF",
                "ENABLE_PCH": "OFF",
                "ENABLE_UNITY": "OFF",
                "CMAKE_C_FLAGS": "-fprofile-instr-generate -fcoverage-mapping",
                "CMAKE_CXX_FLAGS": "-fprofile-instr-generate -fcoverage-mapping",
                "CMAKE_EXE_LINKER_FLAGS": "-fprofile-instr-generate"
            }
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Sentry with Crashpad",
            "description": "RelWithDebInfo build with Sentry crashpad backend",
            "inherits": "relwithdebinfo",
            "binaryDir": "build-sentry-crashpad"
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Sentry with Breakpad",
            "description": "RelWithDebInfo build with Sentry breakpad backend for macOS",
            "inherits": "relwithdebinfo",
            "binaryDir": "build-sentry-breakpad",
            "cacheVariables": {
                "CMAKE_OSX_ARCHITECTURES": "x86_64;arm64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release"
        },
        {
            "name": "relwithdebinfo",
            "hidden": true,
            "displayName": "Build RelWithDebInfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "coverage",
            "displayName": "Build Coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "asan",
            "displayName": "Build with AddressSanitizer",
            "configurePreset": "asan"
        },
        {
            "name": "tsan",
            "displayName": "Build with ThreadSanitizer",
            "configurePreset": "tsan"
        },
        {
            "name": "msan",
            "displayName": "Build with MemorySanitizer",
            "configurePreset": "msan"
        },
        {
            "name": "ubsan",
            "displayName": "Build with UBSanitizer",
            "configurePreset": "ubsan"
        },
        {
            "name": "macos-universal",
            "hidden": true,
            "displayName": "Build macOS Universal",
            "configurePreset": "macos-universal"
        },
        {
            "name": "fuzzer",
            "displayName": "Build libFuzzer harnesses",
            "configurePreset": "fuzzer",
            "targets": [
                "fuzz_deserialize",
                "fuzz_ic_blob",
                "fuzz_structured",
                "fuzz_waveform",
                "fuzz_clipboard",
                "fuzz_old_format",
                "fuzz_ic_registry",
                "fuzz_codegen",
                "fuzz_round_trip",
                "fuzz_ic_file",
                "fuzz_copy_panda",
                "fuzz_undo"
            ]
        },
        {
            "name": "fuzzer-coverage",
            "displayName": "Build fuzzer-coverage harnesses",
            "configurePreset": "fuzzer-coverage",
            "targets": [
                "fuzz_deserialize",
                "fuzz_ic_blob",
                "fuzz_structured",
                "fuzz_waveform",
                "fuzz_clipboard",
                "fuzz_old_format",
                "fuzz_ic_registry",
                "fuzz_codegen",
                "fuzz_round_trip",
                "fuzz_ic_file",
                "fuzz_copy_panda",
                "fuzz_undo"
            ]
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Build with Sentry Crashpad",
            "configurePreset": "sentry-crashpad"
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Build with Sentry Breakpad",
            "configurePreset": "sentry-breakpad"
        }
    ],
    "testPresets": [
        {
            "name": "base",
            "hidden": true,
            "execution": {
                "jobs": 8
            },
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "LSAN_OPTIONS": "suppressions=${sourceDir}/Tests/lsan_suppressions.txt"
            }
        },
        {
            "name": "debug",
            "displayName": "Test Debug",
            "configurePreset": "debug",
            "inherits": "base"
        },
        {
            "name": "release",
            "displayName": "Test Release",
            "configurePreset": "release",
            "inherits": "base"
        },
        {
            "name": "relwithdebinfo",
            "hidden": true,
            "displayName": "Test RelWithDebInfo",
            "configurePreset": "relwithdebinfo",
            "inherits": "base"
        },
        {
            "name": "coverage",
            "displayName": "Test Coverage",
            "configurePreset": "coverage",
            "inherits": "base"
        },
        {
            "name": "asan",
            "displayName": "Test with AddressSanitizer",
            "configurePreset": "asan",
            "inherits": "base"
        },
        {
            "name": "tsan",
            "displayName": "Test with ThreadSanitizer",
            "configurePreset": "tsan",
            "inherits": "base"
        },
        {
            "name": "msan",
            "displayName": "Test with MemorySanitizer",
            "configurePreset": "msan",
            "inherits": "base"
        },
        {
            "name": "ubsan",
            "displayName": "Test with UBSanitizer",
            "configurePreset": "ubsan",
            "inherits": "base"
        },
        {
            "name": "sentry-crashpad",
            "displayName": "Test with Sentry Crashpad",
            "configurePreset": "sentry-crashpad",
            "inherits": "base"
        },
        {
            "name": "sentry-breakpad",
            "displayName": "Test with Sentry Breakpad",
            "configurePreset": "sentry-breakpad",
            "inherits": "base"
        }
    ]
}
