---
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import DownloadPlatform from '../../components/DownloadPlatform.astro';
import { getStaticLocalePaths, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

const GITHUB_REPO_OWNER = "GIBIS-UNIFESP";
const GITHUB_REPO_NAME = "wiRedPanda";
const GITHUB_RELEASES_PAGE_URL = `https://github.com/${GITHUB_REPO_OWNER}/${GITHUB_REPO_NAME}/releases`;

const archInstallCommand = "yay -S wiredpanda";
const debianInstallCommand = "apt-get install wiredpanda";

// Pass translations to client-side script
const clientTranslations = {
  fetching: t('download.fetching'),
  errorHeading: t('download.errorHeading'),
  linkNotAvailableRelease: t('download.linkNotAvailableRelease'),
  versionText: t('download.versionText'),
  errorFetching: t('download.errorFetching'),
  errorNotFound: t('download.errorNotFound'),
  errorRateLimit: t('download.errorRateLimit'),
  errorConnection: t('download.errorConnection'),
};
---

<Base pageTitle={t('download.title')}>
  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
    <h2 class="text-4xl font-bold text-gray-900 dark:text-white mb-6">{t('download.heading')}</h2>

    <div id="release-info-container" class="mb-8 min-h-[50px]">
      <p id="release-version-text" class="text-gray-600 dark:text-gray-300">{t('download.fetching')}</p>
      <div id="error-message-container" class="hidden bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-500/40 rounded-xl p-4 mt-4 text-left">
        <p class="text-red-600 dark:text-red-400 font-semibold">{t('download.errorHeading')}</p>
        <p id="error-text" class="text-red-500 dark:text-red-300 mt-1"></p>
        <p class="text-gray-600 dark:text-gray-300 mt-2">
          {t('download.errorVisit')} <a href={GITHUB_RELEASES_PAGE_URL} target="_blank" rel="noopener noreferrer" class="text-brand-light-blue hover:underline">{t('download.errorVisitLink')}</a> {t('download.errorVisitSuffix')}
        </p>
      </div>
    </div>

    <div class="rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm p-8 mb-10 flex flex-col sm:flex-row items-center justify-around gap-8">
      <div>
        <a id="windows-download-link"
          class="flex flex-col items-center gap-2 disabled-link"
          href={GITHUB_RELEASES_PAGE_URL} target="_blank" rel="noopener noreferrer" aria-disabled="true"
        >
          <Icon name="platforms/windows" class="platform-icon disabled-icon" />
          <span class="text-gray-600 dark:text-gray-300">{t('download.windows')}</span>
        </a>
        <small id="windows-status" class="text-gray-400 dark:text-gray-500 text-xs hidden">{t('download.linkNotAvailable')}</small>
      </div>
      <div>
        <a id="linux-download-link"
          class="flex flex-col items-center gap-2 disabled-link"
          href={GITHUB_RELEASES_PAGE_URL} target="_blank" rel="noopener noreferrer" aria-disabled="true"
        >
          <Icon name="platforms/linux" class="platform-icon disabled-icon" />
          <span class="text-gray-600 dark:text-gray-300">{t('download.linux')}</span>
        </a>
        <small id="linux-status" class="text-gray-400 dark:text-gray-500 text-xs hidden">{t('download.linkNotAvailable')}</small>
      </div>
      <div>
        <a id="macos-download-link"
          class="flex flex-col items-center gap-2 disabled-link"
          href={GITHUB_RELEASES_PAGE_URL} target="_blank" rel="noopener noreferrer" aria-disabled="true"
        >
          <Icon name="platforms/macos" class="platform-icon disabled-icon" />
          <span class="text-gray-600 dark:text-gray-300">{t('download.macos')}</span>
        </a>
        <small id="macos-status" class="text-gray-400 dark:text-gray-500 text-xs hidden">{t('download.linkNotAvailable')}</small>
      </div>
    </div>

    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{t('download.otherOptions')}</h2>
    <p class="text-gray-600 dark:text-gray-300 mb-6">
      {t('download.packageManagers')}
    </p>

    <div class="max-w-lg mx-auto rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm px-5 py-4 mb-8 space-y-1 divide-y divide-gray-200/60 dark:divide-brand-blue/15">
      <DownloadPlatform platform="arch" platformName="Arch-based" installCommand={archInstallCommand} />
      <DownloadPlatform platform="debian" platformName="Debian-based" installCommand={debianInstallCommand} />
    </div>

    <p class="text-gray-600 dark:text-gray-300">
      {t('download.allReleases')}
      <a href={GITHUB_RELEASES_PAGE_URL} target="_blank" rel="noopener noreferrer" class="text-brand-light-blue hover:underline">
        {t('download.officialGithub')}
      </a>.
    </p>
  </section>

  <!-- Copy toast -->
  <div
    id="copy-toast"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-full opacity-0 z-50 pointer-events-none px-4 py-2.5 rounded-lg bg-gray-800 dark:bg-gray-700 text-white text-sm font-medium shadow-lg transition-all duration-300 ease-out"
    role="status"
    aria-live="polite"
  >
    {t('download.copiedToClipboard')}
  </div>
</Base>

<script define:vars={{ GITHUB_REPO_OWNER, GITHUB_REPO_NAME, GITHUB_RELEASES_PAGE_URL, clientTranslations }}>
  const releaseVersionTextEl = document.getElementById('release-version-text');
  const errorMessageContainerEl = document.getElementById('error-message-container');
  const errorTextEl = document.getElementById('error-text');

  const windowsLinkEl = document.getElementById('windows-download-link');
  const linuxLinkEl = document.getElementById('linux-download-link');
  const macosLinkEl = document.getElementById('macos-download-link');

  const windowsStatusEl = document.getElementById('windows-status');
  const linuxStatusEl = document.getElementById('linux-status');
  const macosStatusEl = document.getElementById('macos-status');

  function setLink(element, url, statusElement) {
    if (url && url !== '#') {
      element.href = url;
      element.classList.remove('disabled-link');
      element.querySelector('.platform-icon').classList.remove('disabled-icon');
      element.removeAttribute('aria-disabled');
      if (statusElement) statusElement.classList.add('hidden');
    } else {
      element.href = GITHUB_RELEASES_PAGE_URL;
      element.classList.add('disabled-link');
      element.querySelector('.platform-icon').classList.add('disabled-icon');
      element.setAttribute('aria-disabled', 'true');
      if (statusElement) {
        statusElement.textContent = clientTranslations.linkNotAvailableRelease;
        statusElement.classList.remove('hidden');
      }
    }
  }

  function showError(message) {
    if (releaseVersionTextEl) releaseVersionTextEl.style.display = 'none';
    if (errorTextEl) errorTextEl.textContent = message;
    if (errorMessageContainerEl) errorMessageContainerEl.classList.remove('hidden');

    setLink(windowsLinkEl, GITHUB_RELEASES_PAGE_URL, windowsStatusEl);
    setLink(linuxLinkEl, GITHUB_RELEASES_PAGE_URL, linuxStatusEl);
    setLink(macosLinkEl, GITHUB_RELEASES_PAGE_URL, macosStatusEl);
  }

  async function fetchLatestRelease() {
    try {
      const response = await fetch(`https://api.github.com/repos/${GITHUB_REPO_OWNER}/${GITHUB_REPO_NAME}/releases/latest`);

      if (!response.ok) {
        let message = clientTranslations.errorFetching.replace('{status}', response.status).replace('{statusText}', response.statusText);
        if (response.status === 404) {
          message = clientTranslations.errorNotFound.replace('{owner}', GITHUB_REPO_OWNER).replace('{repo}', GITHUB_REPO_NAME);
        } else if (response.status === 403) {
          message = clientTranslations.errorRateLimit;
        }
        console.error(message);
        showError(message);
        return;
      }

      const latestRelease = await response.json();
      const releaseVersion = latestRelease.tag_name || "latest";

      if (releaseVersionTextEl) {
        releaseVersionTextEl.textContent = clientTranslations.versionText.replace('{version}', releaseVersion);
      }
      if (errorMessageContainerEl) errorMessageContainerEl.classList.add('hidden');

      let windowsUrl = null;
      let linuxUrl = null;
      let macosUrl = null;

      if (latestRelease && latestRelease.assets) {
        const windowsAsset = latestRelease.assets.find(asset =>
          asset.name.includes("Windows") && (asset.name.endsWith(".zip") || asset.name.endsWith(".exe"))
        );
        const linuxAsset = latestRelease.assets.find(asset =>
          (asset.name.includes("Ubuntu") || asset.name.includes("Linux")) && asset.name.endsWith(".AppImage")
        );
        const macosAsset = latestRelease.assets.find(asset =>
          asset.name.includes("macOS") && asset.name.endsWith(".dmg")
        );

        if (windowsAsset) windowsUrl = windowsAsset.browser_download_url;
        if (linuxAsset) linuxUrl = linuxAsset.browser_download_url;
        if (macosAsset) macosUrl = macosAsset.browser_download_url;
      } else {
        console.warn("Latest release found, but it contains no assets.");
      }

      setLink(windowsLinkEl, windowsUrl, windowsStatusEl);
      setLink(linuxLinkEl, linuxUrl, linuxStatusEl);
      setLink(macosLinkEl, macosUrl, macosStatusEl);

    } catch (error) {
      const message = clientTranslations.errorConnection;
      console.error("Error fetching or parsing latest release data:", error);
      showError(message);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fetchLatestRelease);
  } else {
    fetchLatestRelease();
  }

  // Setup analytics tracking for direct downloads
  const trackDownload = (platform) => {
    if (typeof window !== 'undefined' && window.umami) {
      window.umami.track('Download', { platform: platform });
    }
  };

  windowsLinkEl?.addEventListener('click', () => trackDownload('Windows'));
  linuxLinkEl?.addEventListener('click', () => trackDownload('Linux'));
  macosLinkEl?.addEventListener('click', () => trackDownload('macOS'));
</script>

<style>
  .platform-icon {
    width: 70px;
    height: 70px;
    color: #777;
    transition: color 0.2s;
  }

  :global(.dark) .platform-icon {
    color: #ddd;
  }

  .platform-icon:hover:not(.disabled-icon) {
    color: var(--color-brand-red);
  }

  .disabled-icon {
    color: #aaa !important;
  }

  :global(.dark) .disabled-icon {
    color: #7a7a7a !important;
  }

  .disabled-link {
    pointer-events: none;
    opacity: 0.6;
    cursor: not-allowed;
  }

  .disabled-link .platform-icon {
    color: #aaa !important;
  }

  :global(.dark) .disabled-link .platform-icon {
    color: #7a7a7a !important;
  }
</style>
