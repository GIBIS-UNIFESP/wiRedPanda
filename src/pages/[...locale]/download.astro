---
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import DownloadPlatform from '../../components/DownloadPlatform.astro';
import { getStaticLocalePaths, useTranslations, type Locale } from '../../i18n';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

const GITHUB_REPO_OWNER = 'GIBIS-UNIFESP';
const GITHUB_REPO_NAME = 'wiRedPanda';
const GITHUB_RELEASES_PAGE_URL = `https://github.com/${GITHUB_REPO_OWNER}/${GITHUB_REPO_NAME}/releases`;

const archInstallCommand = 'yay -S wiredpanda';
const debianInstallCommand = 'sudo apt-get install wiredpanda';
---

<Base pageTitle={t('download.title')}>
  <!-- Config for client-side script (avoids define:vars / is:inline) -->
  <div
    id="download-config"
    hidden
    data-owner={GITHUB_REPO_OWNER}
    data-repo={GITHUB_REPO_NAME}
    data-releases-url={GITHUB_RELEASES_PAGE_URL}
    data-tr-version={t('download.versionText')}
    data-tr-error-fetching={t('download.errorFetching')}
    data-tr-error-not-found={t('download.errorNotFound')}
    data-tr-error-rate-limit={t('download.errorRateLimit')}
    data-tr-error-connection={t('download.errorConnection')}
  >
  </div>

  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-6">{t('download.heading')}</h1>

    <div id="release-info-container" class="mb-8 min-h-[50px]">
      <p id="release-version-text" class="text-gray-600 dark:text-gray-300">
        {t('download.fetching')}
      </p>
      <div
        id="error-message-container"
        class="hidden bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-500/40 rounded-xl p-4 mt-4 text-left"
      >
        <p class="text-red-600 dark:text-red-400 font-semibold">{t('download.errorHeading')}</p>
        <p id="error-text" class="text-red-500 dark:text-red-300 mt-1"></p>
        <p class="text-gray-600 dark:text-gray-300 mt-2">
          {t('download.errorVisit')}
          <a
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-light-blue hover:underline">{t('download.errorVisitLink')}</a
          >
          {t('download.errorVisitSuffix')}
        </p>
      </div>
    </div>

    <div
      class="rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm p-8 mb-10 flex flex-col sm:flex-row items-center justify-around gap-8"
    >
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/windows" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.windows')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id="windows-x64-link"
            class="arch-chip disabled-chip"
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled="true">{t('download.x86_64')}</a
          >
          <a
            id="windows-arm64-link"
            class="arch-chip disabled-chip"
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled="true">{t('download.arm64')}</a
          >
        </div>
      </div>
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/linux" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.linux')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id="linux-x64-link"
            class="arch-chip disabled-chip"
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled="true">{t('download.x86_64')}</a
          >
          <a
            id="linux-arm64-link"
            class="arch-chip disabled-chip"
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled="true">{t('download.arm64')}</a
          >
        </div>
      </div>
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/macos" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.macos')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id="macos-universal-link"
            class="arch-chip disabled-chip"
            href={GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled="true">{t('download.universal')}</a
          >
        </div>
      </div>
    </div>

    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      {t('download.otherOptions')}
    </h2>
    <p class="text-gray-600 dark:text-gray-300 mb-6">
      {t('download.packageManagers')}
    </p>

    <div
      class="max-w-lg mx-auto rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm px-5 py-4 mb-8 space-y-1 divide-y divide-gray-200/60 dark:divide-brand-blue/15"
    >
      <DownloadPlatform
        platform="arch"
        platformName={t('download.platformArch')}
        installCommand={archInstallCommand}
        copyLabel={t('download.copyCommand').replace('{platform}', t('download.platformArch'))}
      />
      <DownloadPlatform
        platform="debian"
        platformName={t('download.platformDebian')}
        installCommand={debianInstallCommand}
        copyLabel={t('download.copyCommand').replace('{platform}', t('download.platformDebian'))}
      />
    </div>

    <p class="text-gray-600 dark:text-gray-300">
      {t('download.allReleases')}
      <a
        href={GITHUB_RELEASES_PAGE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-light-blue hover:underline"
      >
        {t('download.officialGithub')}
      </a>.
    </p>
  </section>

  <!-- Copy toast (shown by wiredpanda:copy-success event) -->
  <div
    id="copy-toast"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-full opacity-0 z-50 pointer-events-none px-4 py-2.5 rounded-lg bg-gray-800 dark:bg-gray-700 text-white text-sm font-medium shadow-lg transition-all duration-300 ease-out"
    role="status"
    aria-live="polite"
  >
    {t('download.copiedToClipboard')}
  </div>
</Base>

<script>
  import { parseReleaseAssets } from '../../lib/release-assets';

  document.addEventListener('astro:page-load', () => {
    const controller = new AbortController();
    const { signal } = controller;
    document.addEventListener('astro:before-preparation', () => controller.abort(), { once: true });

    const config = document.getElementById('download-config') as HTMLElement | null;
    if (!config) return;

    const owner = config.dataset['owner'] ?? '';
    const repo = config.dataset['repo'] ?? '';
    const releasesUrl = config.dataset['releasesUrl'] ?? '';
    const translations = {
      versionText: config.dataset['trVersion'] ?? '',
      errorFetching: config.dataset['trErrorFetching'] ?? '',
      errorNotFound: config.dataset['trErrorNotFound'] ?? '',
      errorRateLimit: config.dataset['trErrorRateLimit'] ?? '',
      errorConnection: config.dataset['trErrorConnection'] ?? '',
    };

    const releaseVersionTextEl = document.getElementById('release-version-text');
    const errorMessageContainerEl = document.getElementById('error-message-container');
    const errorTextEl = document.getElementById('error-text');

    const windowsX64El = document.getElementById('windows-x64-link');
    const windowsArmEl = document.getElementById('windows-arm64-link');
    const linuxX64El = document.getElementById('linux-x64-link');
    const linuxArmEl = document.getElementById('linux-arm64-link');
    const macosEl = document.getElementById('macos-universal-link');

    function setChip(el: HTMLElement | null, url: string | null) {
      if (!el) return;
      if (url) {
        (el as HTMLAnchorElement).href = url;
        el.classList.remove('disabled-chip');
        el.removeAttribute('aria-disabled');
      } else {
        (el as HTMLAnchorElement).href = releasesUrl;
        el.classList.add('disabled-chip');
        el.setAttribute('aria-disabled', 'true');
      }
    }

    function showError(message: string) {
      if (releaseVersionTextEl) releaseVersionTextEl.style.display = 'none';
      if (errorTextEl) errorTextEl.textContent = message;
      if (errorMessageContainerEl) errorMessageContainerEl.classList.remove('hidden');
    }

    async function fetchLatestRelease() {
      try {
        const response = await fetch(
          `https://api.github.com/repos/${owner}/${repo}/releases/latest`
        );

        if (!response.ok) {
          let message = translations.errorFetching
            .replace('{status}', String(response.status))
            .replace('{statusText}', response.statusText);
          if (response.status === 404) {
            message = translations.errorNotFound.replace('{owner}', owner).replace('{repo}', repo);
          } else if (response.status === 403) {
            message = translations.errorRateLimit;
          }
          console.error(message);
          showError(message);
          return;
        }

        const latestRelease = (await response.json()) as {
          tag_name?: string;
          assets?: { name: string; browser_download_url: string }[];
        };
        const releaseVersion = latestRelease.tag_name ?? 'latest';

        if (releaseVersionTextEl) {
          releaseVersionTextEl.textContent = translations.versionText.replace(
            '{version}',
            releaseVersion
          );
        }
        if (errorMessageContainerEl) errorMessageContainerEl.classList.add('hidden');

        if (latestRelease.assets) {
          const parsed = parseReleaseAssets(latestRelease.assets);
          setChip(windowsX64El, parsed.windowsX64?.browser_download_url ?? null);
          setChip(windowsArmEl, parsed.windowsArm64?.browser_download_url ?? null);
          setChip(linuxX64El, parsed.linuxX64?.browser_download_url ?? null);
          setChip(linuxArmEl, parsed.linuxArm64?.browser_download_url ?? null);
          setChip(macosEl, parsed.macosUniversal?.browser_download_url ?? null);
        } else {
          console.warn('Latest release found, but it contains no assets.');
        }
      } catch (error) {
        console.error('Error fetching or parsing latest release data:', error);
        showError(translations.errorConnection);
      }
    }

    void fetchLatestRelease();

    // Show copy-toast when DownloadPlatform signals a successful copy
    window.addEventListener(
      'wiredpanda:copy-success',
      () => {
        const toast = document.getElementById('copy-toast');
        if (!toast) return;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        setTimeout(() => {
          toast.classList.remove('translate-y-0', 'opacity-100');
          toast.classList.add('translate-y-full', 'opacity-0');
        }, 2000);
      },
      { signal }
    );

    // Analytics: track download clicks
    function trackDownload(platform: string) {
      window.umami?.track('Download', { platform });
    }

    windowsX64El?.addEventListener('click', () => trackDownload('Windows-x64'), { signal });
    windowsArmEl?.addEventListener('click', () => trackDownload('Windows-arm64'), { signal });
    linuxX64El?.addEventListener('click', () => trackDownload('Linux-x64'), { signal });
    linuxArmEl?.addEventListener('click', () => trackDownload('Linux-arm64'), { signal });
    macosEl?.addEventListener('click', () => trackDownload('macOS'), { signal });
  });
</script>

<style>
  .platform-icon {
    width: 70px;
    height: 70px;
    color: #777;
    transition: color 0.2s;
  }

  :global(.dark) .platform-icon {
    color: #ddd;
  }

  .arch-chip {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid var(--color-brand-blue, #4a90d9);
    color: var(--color-brand-light-blue, #5aa8f0);
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .arch-chip:not(.disabled-chip):hover {
    background-color: var(--color-brand-blue, #4a90d9);
    color: #fff;
  }

  /* Loading state: click still works (goes to releases page as fallback) */
  .disabled-chip {
    opacity: 0.4;
    cursor: default;
  }
</style>
