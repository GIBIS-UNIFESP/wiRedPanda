---
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import DownloadPlatform from '../../components/DownloadPlatform.astro';
import { getStaticLocalePaths, useTranslations, type Locale } from '../../i18n';
import releaseData from '../../data/latest-release.json';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);

const GITHUB_REPO_OWNER = 'GIBIS-UNIFESP';
const GITHUB_REPO_NAME = 'wiRedPanda';
const GITHUB_RELEASES_PAGE_URL = `https://github.com/${GITHUB_REPO_OWNER}/${GITHUB_REPO_NAME}/releases`;

const archInstallCommand = 'yay -S wiredpanda';
const debianInstallCommand = 'sudo apt-get install wiredpanda';

interface DownloadChip {
  id: string;
  href: string | null;
  label: string;
}

const chips: DownloadChip[] = [
  { id: 'windows-x64-link', href: releaseData.windowsX64, label: t('download.x86_64') },
  { id: 'windows-arm64-link', href: releaseData.windowsArm64, label: t('download.arm64') },
  { id: 'linux-x64-link', href: releaseData.linuxX64, label: t('download.x86_64') },
  { id: 'linux-arm64-link', href: releaseData.linuxArm64, label: t('download.arm64') },
  { id: 'macos-universal-link', href: releaseData.macosUniversal, label: t('download.universal') },
];
const chipById = Object.fromEntries(chips.map((c) => [c.id, c]));
---

<Base pageTitle={t('download.title')}>
  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-6">{t('download.heading')}</h1>

    <p class="text-gray-600 dark:text-gray-300 mb-8">
      {t('download.versionText').replace('{version}', releaseData.version)}
    </p>

    <div
      class="rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm p-8 mb-10 flex flex-col sm:flex-row items-center justify-around gap-8"
    >
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/windows" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.windows')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id={chipById['windows-x64-link']!.id}
            class:list={['arch-chip', { 'disabled-chip': !chipById['windows-x64-link']!.href }]}
            href={chipById['windows-x64-link']!.href ?? GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled={chipById['windows-x64-link']!.href ? undefined : 'true'}
            >{chipById['windows-x64-link']!.label}</a
          >
          <a
            id={chipById['windows-arm64-link']!.id}
            class:list={['arch-chip', { 'disabled-chip': !chipById['windows-arm64-link']!.href }]}
            href={chipById['windows-arm64-link']!.href ?? GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled={chipById['windows-arm64-link']!.href ? undefined : 'true'}
            >{chipById['windows-arm64-link']!.label}</a
          >
        </div>
      </div>
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/linux" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.linux')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id={chipById['linux-x64-link']!.id}
            class:list={['arch-chip', { 'disabled-chip': !chipById['linux-x64-link']!.href }]}
            href={chipById['linux-x64-link']!.href ?? GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled={chipById['linux-x64-link']!.href ? undefined : 'true'}
            >{chipById['linux-x64-link']!.label}</a
          >
          <a
            id={chipById['linux-arm64-link']!.id}
            class:list={['arch-chip', { 'disabled-chip': !chipById['linux-arm64-link']!.href }]}
            href={chipById['linux-arm64-link']!.href ?? GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled={chipById['linux-arm64-link']!.href ? undefined : 'true'}
            >{chipById['linux-arm64-link']!.label}</a
          >
        </div>
      </div>
      <div class="flex flex-col items-center gap-2">
        <Icon name="platforms/macos" class="platform-icon" />
        <span class="text-gray-600 dark:text-gray-300">{t('download.macos')}</span>
        <div class="flex gap-2 mt-1">
          <a
            id={chipById['macos-universal-link']!.id}
            class:list={['arch-chip', { 'disabled-chip': !chipById['macos-universal-link']!.href }]}
            href={chipById['macos-universal-link']!.href ?? GITHUB_RELEASES_PAGE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-disabled={chipById['macos-universal-link']!.href ? undefined : 'true'}
            >{chipById['macos-universal-link']!.label}</a
          >
        </div>
      </div>
    </div>

    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      {t('download.otherOptions')}
    </h2>
    <p class="text-gray-600 dark:text-gray-300 mb-6">
      {t('download.packageManagers')}
    </p>

    <div
      class="max-w-lg mx-auto rounded-xl border border-brand-blue/20 dark:border-brand-blue/40 bg-bg-card-light dark:bg-bg-card backdrop-blur-sm px-5 py-4 mb-8 space-y-1 divide-y divide-gray-200/60 dark:divide-brand-blue/15"
    >
      <DownloadPlatform
        platform="arch"
        platformName={t('download.platformArch')}
        installCommand={archInstallCommand}
        copyLabel={t('download.copyCommand').replace('{platform}', t('download.platformArch'))}
      />
      <DownloadPlatform
        platform="debian"
        platformName={t('download.platformDebian')}
        installCommand={debianInstallCommand}
        copyLabel={t('download.copyCommand').replace('{platform}', t('download.platformDebian'))}
      />
    </div>

    <p class="text-gray-600 dark:text-gray-300">
      {t('download.allReleases')}{' '}
      <a
        href={GITHUB_RELEASES_PAGE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-light-blue hover:underline"
      >
        {t('download.officialGithub')}
      </a>.
    </p>
  </section>

  <!-- Copy toast (shown by wiredpanda:copy-success event) -->
  <div
    id="copy-toast"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-full opacity-0 z-50 pointer-events-none px-4 py-2.5 rounded-lg bg-gray-800 dark:bg-gray-700 text-white text-sm font-medium shadow-lg transition-all duration-300 ease-out"
    role="status"
    aria-live="polite"
  >
    {t('download.copiedToClipboard')}
  </div>
</Base>

<script>
  import { COPY_SUCCESS_EVENT } from '../../lib/events';

  document.addEventListener('astro:page-load', () => {
    const controller = new AbortController();
    const { signal } = controller;
    document.addEventListener('astro:before-preparation', () => controller.abort(), { once: true });

    // Show copy-toast when DownloadPlatform signals a successful copy
    window.addEventListener(
      COPY_SUCCESS_EVENT,
      () => {
        const toast = document.getElementById('copy-toast');
        if (!toast) return;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        setTimeout(() => {
          toast.classList.remove('translate-y-0', 'opacity-100');
          toast.classList.add('translate-y-full', 'opacity-0');
        }, 2000);
      },
      { signal }
    );

    // Analytics: track download clicks. Hrefs are resolved statically at
    // build time (see scripts/update-release-data.mjs) — this script only
    // attaches click tracking, it doesn't fetch or set anything.
    function trackDownload(platform: string) {
      window.umami?.track('Download', { platform });
    }

    const platformById: Record<string, string> = {
      'windows-x64-link': 'Windows-x64',
      'windows-arm64-link': 'Windows-arm64',
      'linux-x64-link': 'Linux-x64',
      'linux-arm64-link': 'Linux-arm64',
      'macos-universal-link': 'macOS',
    };
    for (const [id, platform] of Object.entries(platformById)) {
      document.getElementById(id)?.addEventListener('click', () => trackDownload(platform), {
        signal,
      });
    }
  });
</script>

<style>
  .platform-icon {
    width: 70px;
    height: 70px;
    color: #777;
    transition: color 0.2s;
  }

  :global(.dark) .platform-icon {
    color: #ddd;
  }

  .arch-chip {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid var(--color-brand-blue, #134074);
    color: var(--color-brand-light-blue, #2da6f4);
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .arch-chip:not(.disabled-chip):hover {
    background-color: var(--color-brand-blue, #134074);
    color: #fff;
  }

  /* No asset for this platform in the latest release: click still works
     (goes to the releases page as a fallback). */
  .disabled-chip {
    opacity: 0.4;
    cursor: default;
  }
</style>
