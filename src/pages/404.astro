---
import Base from '../layouts/Base.astro';
import { getLocaleFromUrl, useTranslations, getLocalePath } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<Base pageTitle={t('404.title')}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] pt-20 text-center px-6">
    <h1 class="text-6xl font-bold text-brand-red mb-4">{t('404.heading')}</h1>
    <p class="text-gray-600 dark:text-gray-300 text-lg max-w-lg leading-relaxed">
      {t('404.message')}
      <br />
      {t('404.submessage')}
    </p>
    <a href={getLocalePath('/', locale)} class="mt-8 px-6 py-3 bg-brand-blue hover:bg-brand-light-blue text-white rounded-lg font-medium transition-colors duration-200">
      {t('404.backHome')}
    </a>
  </div>
</Base>
