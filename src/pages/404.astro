---
import Base from '../layouts/Base.astro';
import {
  getLocaleFromUrl,
  useTranslations,
  getLocalePath,
  getAllLocales,
  defaultLocale,
  getLocaleDir,
  getHtmlLang,
} from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const siteBase = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build 404 translations for all non-default locales to pass to the client.
// The page is always served as English by the static host, so client-side JS
// detects the user's locale (from the URL that caused the 404, then from
// browser language) and updates the visible text — and its lang/dir — to match.
const localeTranslations = Object.fromEntries(
  getAllLocales()
    .filter((l) => l !== defaultLocale)
    .map((l) => {
      const tl = useTranslations(l);
      return [
        l,
        {
          heading: tl('404.heading'),
          message: tl('404.message'),
          submessage: tl('404.submessage'),
          backHome: tl('404.backHome'),
          dir: getLocaleDir(l),
          htmlLang: getHtmlLang(l),
        },
      ];
    })
);
---

<Base pageTitle={t('404.title')}>
  <div
    id="err-content"
    class="flex flex-col items-center justify-center min-h-[60vh] pt-20 text-center px-6"
  >
    <h1 id="err-heading" class="text-6xl font-bold text-brand-red mb-4">{t('404.heading')}</h1>
    <p class="text-gray-600 dark:text-gray-300 text-lg max-w-lg leading-relaxed">
      <span id="err-message">{t('404.message')}</span>
      <br />
      <span id="err-submessage">{t('404.submessage')}</span>
    </p>
    <a
      id="err-back"
      href={getLocalePath('/', locale)}
      class="mt-8 px-6 py-3 bg-brand-blue hover:bg-brand-light-blue text-white rounded-lg font-medium transition-colors duration-200"
    >
      {t('404.backHome')}
    </a>
  </div>

  <!-- Config for client-side script (avoids define:vars / is:inline, matching download.astro) -->
  <div
    id="notfound-config"
    hidden
    data-site-base={siteBase}
    data-locale-translations={JSON.stringify(localeTranslations)}
  >
  </div>
</Base>

<script>
  import { matchBrowserLanguage } from '../i18n';

  interface NotFoundTranslation {
    heading: string;
    message: string;
    submessage: string;
    backHome: string;
    dir: string;
    htmlLang: string;
  }

  document.addEventListener('astro:page-load', () => {
    const config = document.getElementById('notfound-config') as HTMLElement | null;
    if (!config) return;

    const siteBase = config.dataset['siteBase'] ?? '';
    const localeTranslations = JSON.parse(config.dataset['localeTranslations'] ?? '{}') as Record<
      string,
      NotFoundTranslation
    >;

    const path = window.location.pathname;
    let stripped = path;
    if (siteBase && path.indexOf(siteBase) === 0) {
      stripped = path.slice(siteBase.length);
    }

    // Detect locale from the URL that triggered the 404.
    // Require an exact match or a '/' separator so that e.g. '/design' does
    // NOT falsely match the 'de' (German) locale prefix.
    let locale: string | null = null;
    for (const loc of Object.keys(localeTranslations)) {
      if (stripped === '/' + loc || stripped.indexOf('/' + loc + '/') === 0) {
        locale = loc;
        break;
      }
    }

    // Fall back to browser language, using the same matching logic this
    // site's main locale-redirect (Base.astro) uses.
    if (!locale) {
      locale = matchBrowserLanguage(navigator.language || '');
    }

    if (!locale) return; // English already rendered server-side

    const tr = localeTranslations[locale];
    if (!tr) return;

    const headingEl = document.getElementById('err-heading');
    const messageEl = document.getElementById('err-message');
    const submessageEl = document.getElementById('err-submessage');
    const backEl = document.getElementById('err-back') as HTMLAnchorElement | null;

    if (headingEl) headingEl.textContent = tr.heading;
    if (messageEl) messageEl.textContent = tr.message;
    if (submessageEl) submessageEl.textContent = tr.submessage;
    if (backEl) {
      backEl.textContent = tr.backHome;
      backEl.href = siteBase + '/' + locale + '/';
    }

    // The rest of the page (Base.astro's chrome) stays in the default locale
    // for a static 404 — only these specific nodes get translated — so scope
    // dir/lang to their shared container, not document.documentElement: the
    // reading direction/lang of THIS translated text must match its language
    // (or RTL locales render their translated text backwards), but setting it
    // on <html> would also mirror the still-English chrome around it.
    const contentEl = document.getElementById('err-content');
    if (contentEl) {
      contentEl.lang = tr.htmlLang;
      contentEl.dir = tr.dir;
    }
  });
</script>
