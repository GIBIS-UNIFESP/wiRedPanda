---
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  getLocaleFromUrl,
  getHtmlLang,
  getLocaleDir,
  useTranslations,
  getOtherLocales,
  getLocalePath,
  defaultLocale,
  getAllLocales,
  localeRedirectMap,
} from '../i18n';
import ogScreenshot from '../images/panda/panda1.png';

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const htmlLang = getHtmlLang(locale);
const localeDir = getLocaleDir(locale);
const otherLocales = getOtherLocales(locale);
const origin = Astro.site?.origin ?? '';

// Data for the locale auto-redirect script (map is defined and tested in src/i18n/index.ts)
const nonDefaultLocales = getAllLocales().filter((l) => l !== defaultLocale);
---

<html lang={htmlLang} dir={localeDir}>
  <head>
    <meta charset="utf-8" />
    <!-- Theme init: must run before any rendering to avoid FOUC -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isDark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}wpanda.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={t('meta.description')} />
    <link rel="canonical" href={`${origin}${getLocalePath(Astro.url.pathname, locale)}`} />
    <link
      rel="alternate"
      hreflang={htmlLang}
      href={`${origin}${getLocalePath(Astro.url.pathname, locale)}`}
    />
    {
      otherLocales.map((altLocale) => (
        <link
          rel="alternate"
          hreflang={getHtmlLang(altLocale)}
          href={`${origin}${getLocalePath(Astro.url.pathname, altLocale)}`}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={`${origin}${getLocalePath(Astro.url.pathname, defaultLocale)}`}
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="wiRedPanda" />
    <meta property="og:title" content={`wiRedPanda | ${pageTitle}`} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:url" content={`${origin}${getLocalePath(Astro.url.pathname, locale)}`} />
    <meta property="og:image" content={`${origin}${ogScreenshot.src}`} />
    <meta property="og:image:width" content={String(ogScreenshot.width)} />
    <meta property="og:image:height" content={String(ogScreenshot.height)} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    {
      otherLocales.map((altLocale) => (
        <meta property="og:locale:alternate" content={getHtmlLang(altLocale).replace('-', '_')} />
      ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`wiRedPanda | ${pageTitle}`} />
    <meta name="twitter:description" content={t('meta.description')} />
    <meta name="twitter:image" content={`${origin}${ogScreenshot.src}`} />
    <ClientRouter />
    <title>wiRedPanda | {pageTitle}</title>
    <script is:inline>
      (function () {
        // Fallback for custom events if DNT is active or script is blocked
        window.umami = window.umami || { track: function () {} };
        var dnt = navigator.doNotTrack || window.doNotTrack || navigator.msDoNotTrack;
        if (dnt !== '1' && dnt !== 'yes') {
          // Guard against re-injection on SPA navigations (is:inline re-runs on each swap)
          if (!document.getElementById('umami-script')) {
            var script = document.createElement('script');
            script.id = 'umami-script';
            script.defer = true;
            script.src = 'https://cloud.umami.is/script.js';
            script.setAttribute('data-website-id', '8cf1c01a-4505-4de2-a5ea-0facfe5a71dd');
            document.head.appendChild(script);
          }
        } else {
          console.info('Analytics disabled to respect Do Not Track preference.');
        }
      })();
    </script>
    <!-- Preserve theme across view transitions (registered once; guard prevents accumulation) -->
    <script is:inline>
      if (!window.__themeTransitionSetup) {
        window.__themeTransitionSetup = true;
        document.addEventListener('astro:before-swap', function (ev) {
          var isDark = document.documentElement.classList.contains('dark');
          ev.newDocument.documentElement.classList.toggle('dark', isDark);
        });
      }
    </script>
  </head>
  <body>
    <Header />
    <main transition:animate="fade" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<!-- Redirect users to their preferred locale on first visit -->
<script
  is:inline
  define:vars={{
    siteBase: import.meta.env.BASE_URL.replace(/\/$/, ''),
    nonDefaultLocales,
    localeRedirectMap,
  }}
>
  (function () {
    if (sessionStorage.getItem('locale-checked')) return;
    sessionStorage.setItem('locale-checked', '1');

    var path = window.location.pathname;
    var base = siteBase;
    var stripped = path;
    if (base && path.indexOf(base) === 0) {
      stripped = path.slice(base.length);
    }

    // Already on any non-default locale path? Skip redirect entirely.
    for (var i = 0; i < nonDefaultLocales.length; i++) {
      var loc = nonDefaultLocales[i];
      if (stripped === '/' + loc || stripped.indexOf('/' + loc + '/') === 0) return;
    }

    // Match browser language against the redirect map (first match wins).
    // Entries with region sub-tags (e.g. 'pt-br') appear before generic codes
    // ('pt') so more specific matches take priority.
    var lang = (navigator.language || '').toLowerCase();
    for (var j = 0; j < localeRedirectMap.length; j++) {
      var prefix = localeRedirectMap[j][0];
      var target = localeRedirectMap[j][1];
      if (lang === prefix || lang.indexOf(prefix + '-') === 0) {
        window.location.replace(base + '/' + target + stripped);
        return;
      }
    }
  })();
</script>
