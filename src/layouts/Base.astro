---
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  getLocaleFromUrl,
  getHtmlLang,
  useTranslations,
  getOtherLocales,
  getLocalePath,
  defaultLocale,
} from '../i18n';

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const htmlLang = getHtmlLang(locale);
const otherLocales = getOtherLocales(locale);
const origin = Astro.site?.origin ?? '';
---

<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <!-- Theme init: must run before any rendering to avoid FOUC -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isDark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}wpanda.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={t('meta.description')} />
    <link rel="canonical" href={`${origin}${getLocalePath(Astro.url.pathname, locale)}`} />
    <link rel="alternate" hreflang={htmlLang} href={`${origin}${getLocalePath(Astro.url.pathname, locale)}`} />
    {
      otherLocales.map((altLocale) => (
        <link
          rel="alternate"
          hreflang={getHtmlLang(altLocale)}
          href={`${origin}${getLocalePath(Astro.url.pathname, altLocale)}`}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${origin}${getLocalePath(Astro.url.pathname, defaultLocale)}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="wiRedPanda" />
    <meta property="og:title" content={`wiRedPanda | ${pageTitle}`} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:url" content={`${origin}${getLocalePath(Astro.url.pathname, locale)}`} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    {
      otherLocales.map((altLocale) => (
        <meta property="og:locale:alternate" content={getHtmlLang(altLocale).replace('-', '_')} />
      ))
    }
    <ClientRouter />
    <title>Panda | {pageTitle}</title>
    <script is:inline>
      (function () {
        // Fallback for custom events if DNT is active
        window.umami = window.umami || { track: function () {} };
        var dnt = navigator.doNotTrack || window.doNotTrack || navigator.msDoNotTrack;
        if (dnt !== '1' && dnt !== 'yes') {
          var script = document.createElement('script');
          script.defer = true;
          script.src = 'https://cloud.umami.is/script.js';
          script.setAttribute('data-website-id', '8cf1c01a-4505-4de2-a5ea-0facfe5a71dd');
          document.head.appendChild(script);
        } else {
          console.info('Analytics disabled to respect Do Not Track preference.');
        }
      })();
    </script>
    <!-- Preserve theme across view transitions -->
    <script is:inline>
      document.addEventListener('astro:before-swap', function (ev) {
        var isDark = document.documentElement.classList.contains('dark');
        ev.newDocument.documentElement.classList.toggle('dark', isDark);
      });
    </script>
  </head>
  <body>
    <Header />
    <main transition:animate="fade" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<!-- Redirect users to their locale on first visit -->
<script is:inline define:vars={{ siteBase: import.meta.env.BASE_URL.replace(/\/$/, '') }}>
  (function () {
    if (sessionStorage.getItem('locale-checked')) return;
    sessionStorage.setItem('locale-checked', '1');

    var path = window.location.pathname;
    var base = siteBase;
    var stripped = path;
    if (base && path.indexOf(base) === 0) {
      stripped = path.slice(base.length);
    }

    // Already on a non-default locale? Skip.
    if (
      stripped.indexOf('/pt-br') === 0 ||
      stripped.indexOf('/es') === 0 ||
      stripped.indexOf('/zh') === 0 ||
      stripped.indexOf('/ja') === 0 ||
      stripped.indexOf('/fr') === 0 ||
      stripped.indexOf('/de') === 0
    )
      return;

    // Check browser language
    var lang = (navigator.language || navigator.userLanguage || '').toLowerCase();
    if (lang.indexOf('pt') === 0) {
      window.location.replace(base + '/pt-br' + stripped);
    } else if (lang.indexOf('es') === 0) {
      window.location.replace(base + '/es' + stripped);
    } else if (lang.indexOf('zh') === 0) {
      window.location.replace(base + '/zh' + stripped);
    } else if (lang.indexOf('ja') === 0) {
      window.location.replace(base + '/ja' + stripped);
    } else if (lang.indexOf('fr') === 0) {
      window.location.replace(base + '/fr' + stripped);
    } else if (lang.indexOf('de') === 0) {
      window.location.replace(base + '/de' + stripped);
    }
  })();
</script>
