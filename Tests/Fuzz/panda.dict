# libFuzzer dictionary for wiRedPanda .panda file format
# Byte sequences that guide mutation toward structurally valid inputs.
#
# Format:  "literal"  or  token="\xHH..."
# All multi-byte integers are big-endian (QDataStream default).

# --- File header ---
magic="\x57\x50\x43\x46"

# --- Common version numbers (quint32 pair: major, minor) ---
ver_4_1="\x00\x00\x00\x04\x00\x00\x00\x01"
ver_4_7="\x00\x00\x00\x04\x00\x00\x00\x07"
ver_5_0="\x00\x00\x00\x05\x00\x00\x00\x00"
ver_5_1="\x00\x00\x00\x05\x00\x00\x00\x01"

# --- Null/empty markers ---
null_string="\xff\xff\xff\xff"
zero_count="\x00\x00\x00\x00"
one_count="\x00\x00\x00\x01"
two_count="\x00\x00\x00\x02"

# --- QVariant typeIds (quint32 big-endian) in Qt_5_12 wire format ---
tid_Bool="\x00\x00\x00\x01"
tid_Int="\x00\x00\x00\x02"
tid_UInt="\x00\x00\x00\x03"
tid_LongLong="\x00\x00\x00\x04"
tid_ULongLong="\x00\x00\x00\x05"
tid_Double="\x00\x00\x00\x06"
tid_QChar="\x00\x00\x00\x07"
tid_QVariantMap="\x00\x00\x00\x08"
tid_QVariantList="\x00\x00\x00\x09"
tid_QString="\x00\x00\x00\x0a"
tid_QStringList="\x00\x00\x00\x0b"
tid_QByteArray="\x00\x00\x00\x0c"
tid_QBitArray="\x00\x00\x00\x0d"
tid_QRect="\x00\x00\x00\x13"
tid_QRectF="\x00\x00\x00\x14"
tid_QSize="\x00\x00\x00\x15"
tid_QSizeF="\x00\x00\x00\x16"
tid_QPoint="\x00\x00\x00\x19"
tid_QPointF="\x00\x00\x00\x1a"
tid_Float="\x00\x00\x00\x26"
tid_QKeySeq_Qt5="\x00\x00\x00\x4b"
tid_QKeySeq_Qt6="\x00\x00\x10\x0b"

# --- isNull byte: 0 = non-null, 1 = null ---
isnull_false="\x00"
isnull_true="\x01"

# --- QMap keys as UTF-16-BE with quint32 byte-length prefix ---
# (4-byte len)(utf-16be chars)
key_pos="\x00\x00\x00\x06\x00\x70\x00\x6f\x00\x73"
key_rotation="\x00\x00\x00\x10\x00\x72\x00\x6f\x00\x74\x00\x61\x00\x74\x00\x69\x00\x6f\x00\x6e"
key_label="\x00\x00\x00\x0a\x00\x6c\x00\x61\x00\x62\x00\x65\x00\x6c"
key_trigger="\x00\x00\x00\x0e\x00\x74\x00\x72\x00\x69\x00\x67\x00\x67\x00\x65\x00\x72"
key_isOn="\x00\x00\x00\x08\x00\x69\x00\x73\x00\x4f\x00\x6e"
key_locked="\x00\x00\x00\x0c\x00\x6c\x00\x6f\x00\x63\x00\x6b\x00\x65\x00\x64"
key_color="\x00\x00\x00\x0a\x00\x63\x00\x6f\x00\x6c\x00\x6f\x00\x72"
