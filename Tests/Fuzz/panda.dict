key_blobRegistry="\x00\x00\x00\x18\x00\x62\x00\x6c\x00\x6f\x00\x62\x00\x52\x00\x65\x00\x67\x00\x69\x00\x73\x00\x74\x00\x72\x00\x79"
key_startPortId="\x00\x00\x00\x16\x00\x73\x00\x74\x00\x61\x00\x72\x00\x74\x00\x50\x00\x6f\x00\x72\x00\x74\x00\x49\x00\x64"
key_endPortId="\x00\x00\x00\x12\x00\x65\x00\x6e\x00\x64\x00\x50\x00\x6f\x00\x72\x00\x74\x00\x49\x00\x64"
key_flippedX="\x00\x00\x00\x10\x00\x66\x00\x6c\x00\x69\x00\x70\x00\x70\x00\x65\x00\x64\x00\x58"
key_flippedY="\x00\x00\x00\x10\x00\x66\x00\x6c\x00\x69\x00\x70\x00\x70\x00\x65\x00\x64\x00\x59"

# --- Item type discriminators (quint32 big-endian) for Serialization::deserialize() ---
item_connection="\x00\x01\x00\x02"
item_element="\x00\x01\x00\x03"

# --- Element types as quint64 big-endian (written by ElementType::operator<<) ---
etype_And="\x00\x00\x00\x00\x00\x00\x00\x05"
etype_Or="\x00\x00\x00\x00\x00\x00\x00\x06"
etype_Not="\x00\x00\x00\x00\x00\x00\x00\x04"
