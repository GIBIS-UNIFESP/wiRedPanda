key_name="\x00\x00\x00\x08\x00\x6e\x00\x61\x00\x6d\x00\x65"
key_serialId="\x00\x00\x00\x10\x00\x73\x00\x65\x00\x72\x00\x69\x00\x61\x00\x6c\x00\x49\x00\x64"
key_skinName="\x00\x00\x00\x10\x00\x73\x00\x6b\x00\x69\x00\x6e\x00\x4e\x00\x61\x00\x6d\x00\x65"
