#include <windows.h>

// Configured by CMake (see the WIN32 block in CMakeLists.txt) so the version
// metadata always matches project(VERSION ...). Do not edit the generated
// wpanda.rc in the build tree; edit this template.

// Application icon (absolute path: the generated file lives in the build tree)
IDI_APPLICATION ICON "@CMAKE_SOURCE_DIR@/App/Resources/Assets/Logos/wpanda.ico"

// Version information
1 VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "GIBIS-UNIFESP"
            VALUE "FileDescription", "wiRedPanda - Logic Circuit Simulator"
            VALUE "FileVersion", "@PROJECT_VERSION@.0"
            VALUE "InternalName", "wiredpanda"
            VALUE "LegalCopyright", "GIBIS-UNIFESP and the wiRedPanda contributors"
            VALUE "OriginalFilename", "wiredpanda.exe"
            VALUE "ProductName", "wiRedPanda - Logic Circuit Simulator"
            VALUE "ProductVersion", "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
