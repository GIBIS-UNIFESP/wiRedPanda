#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --buildsystem=cmake+ninja

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release

# No override_dh_auto_install: CMakeLists.txt's own install() rules now cover the
# binary, .desktop, all hicolor icon sizes (26x26..128x128 + 256x256 + scalable svg),
# the shared-mime-info definition, the AppStream metainfo, and Examples/ — plain
# dh_auto_install is enough. Licensing comes from debian/copyright, not a raw
# LICENSE copy.
