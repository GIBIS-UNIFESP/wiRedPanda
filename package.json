{
  "name": "panda-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=DEP0205' astro dev",
    "build": "NODE_OPTIONS='--disable-warning=DEP0205' astro build",
    "preview": "NODE_OPTIONS='--disable-warning=DEP0205' astro preview",
    "check": "NODE_OPTIONS='--disable-warning=DEP0205' astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "stylelint": "stylelint \"src/**/*.{css,astro}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,astro}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^7.1.1",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "@iconify-json/circle-flags": "^1.2.10",
    "@tailwindcss/vite": "^4.3.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
